# =============================================================================
# Agendo — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the required values.
#
#   cp .env.example .env.local
#
# The Next.js app reads .env.local directly.
# The worker reads env via ecosystem.config.js, which loads .env.local with dotenv.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgresql://agendo:agendo@localhost:5432/agendo

# JWT secret for API authentication (min 16 characters)
# Generate with: openssl rand -hex 32
JWT_SECRET=

# -----------------------------------------------------------------------------
# App Config (optional — defaults shown)
# -----------------------------------------------------------------------------

NODE_ENV=development
PORT=4100
TERMINAL_WS_PORT=4101
# Terminal port exposed to the browser (must match TERMINAL_WS_PORT)
NEXT_PUBLIC_TERMINAL_WS_PORT=4101

# -----------------------------------------------------------------------------
# Worker Config (optional — defaults shown)
# -----------------------------------------------------------------------------

WORKER_ID=worker-1
WORKER_POLL_INTERVAL_MS=2000
WORKER_MAX_CONCURRENT_JOBS=3
STALE_JOB_THRESHOLD_MS=120000
HEARTBEAT_INTERVAL_MS=30000

# -----------------------------------------------------------------------------
# Paths (optional — defaults shown)
# -----------------------------------------------------------------------------

# Directory for session log files
LOG_DIR=./logs

# Colon-separated list of directories agents are allowed to work in
ALLOWED_WORKING_DIRS=$HOME/projects:/tmp

# Path to the bundled MCP server entry point
MCP_SERVER_PATH=./dist/mcp-server.js

# -----------------------------------------------------------------------------
# Internal (set automatically by the worker — no need to configure)
# -----------------------------------------------------------------------------

# Base URL the MCP server uses to call the agendo API
# AGENDO_URL=http://localhost:4100

# Optional: URL for the server-monitor-api (system stats dashboard card).
# If not running, the dashboard card gracefully shows "unavailable".
# MONITOR_URL=http://localhost:9876

# -----------------------------------------------------------------------------
# Terminal (optional)
# -----------------------------------------------------------------------------

# Separate JWT secret for the terminal WebSocket server.
# Falls back to JWT_SECRET if not set.
TERMINAL_JWT_SECRET=

# -----------------------------------------------------------------------------
# Push Notifications (optional — disabled if not set)
# -----------------------------------------------------------------------------

# Generate VAPID keys with: npx web-push generate-vapid-keys

NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
