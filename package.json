{
  "name": "agendo",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port ${PORT:-4100}",
    "build": "next build",
    "build:all": "pnpm typecheck && pnpm build && pnpm worker:build && pnpm build:mcp",
    "start": "next start --port ${PORT:-4100}",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit",
    "db:setup": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/lib/db/seed.ts",
    "terminal:dev": "tsx watch src/terminal/server.ts",
    "worker:dev": "tsx watch src/worker/index.ts",
    "dev:all": "concurrently -k -n app,worker,term -c cyan,yellow,green \"pnpm dev\" \"pnpm worker:dev\" \"pnpm terminal:dev\"",
    "worker:build": "esbuild src/worker/index.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/worker/index.js --tsconfig=tsconfig.worker.json --external:pg-native --external:bufferutil --external:utf-8-validate --external:pino-pretty --external:@anthropic-ai/claude-agent-sdk --loader:.md=text",
    "build:mcp": "tsx src/lib/mcp/build.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:integrations": "tsx scripts/seed-repo-integration-capabilities.ts",
    "vapid:generate": "npx web-push generate-vapid-keys",
    "prepare": "husky"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.14.1",
    "@anthropic-ai/claude-agent-sdk": "^0.2.72",
    "@anthropic-ai/sdk": "^0.77.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@modelcontextprotocol/ext-apps": "^1.2.2",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@tanstack/react-virtual": "3.13.18",
    "@types/diff": "^8.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "ansi-to-html": "^0.7.2",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "cmdk": "^1.1.1",
    "date-fns": "^4",
    "diff": "^8.0.3",
    "drizzle-orm": "^0.44",
    "isomorphic-dompurify": "^2.36.0",
    "lucide-react": "^0.474",
    "next": "16.1.6",
    "node-pty": "^1.1.0",
    "pg": "^8",
    "pg-boss": "^10",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-grid-layout": "^2.2.2",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2",
    "tailwind-merge": "^3",
    "tsx": "^4",
    "web-push": "^3.6.7",
    "ws": "^8.19.0",
    "zod": "^3",
    "zustand": "5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/pg": "^8",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-grid-layout": "^2.1.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31",
    "esbuild": "^0.27.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nano-banana": "^0.0.0",
    "prettier": "^3.8.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "typescript-eslint": "^8.56.0",
    "vitest": "^3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored"
    ],
    "*.{ts,tsx,js,jsx,json,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
